# Variables de la stack Airflow locale (airflow/start.sh, dags/, src/train.py en subprocess) —
# copier en airflow/.env.test et airflow/.env.production (tous deux gitignorés). Mêmes clés dans
# les deux fichiers, valeurs vides quand non applicable (ex. AWS_* en test).
#
# Airflow reste local (jamais déployé) — ces deux fichiers ne sont jamais copiés ailleurs,
# contrairement à api/.env.production ou dashboard/.env.production.

# ── Bascule test/prod des DAGs (dags/config.py) ────────────────────────────────
APP_ENV=test

# ── Base de données (conteneur fraud-db du réseau Docker Airflow en test, Neon en prod) ──
DATABASE_URL=postgresql://fraud:fraud@fraud-db:5432/fraud
POSTGRES_USER=fraud
POSTGRES_PASSWORD=fraud
POSTGRES_DB=fraud

# ── API de prédiction (appelée par le DAG ETL & Fraud Detection) ──────────────
FRAUD_API_URL=http://localhost:8000
FRAUD_THRESHOLD=0.7
# Fréquence du DAG dag_etl_fraud_detection (fetch_trx/store_trx/fraud_detect) — expression cron
DAG_ETL_FRAUD_DETECTION_CRON=* * * * *

# ── MLflow (train_model.py : comparaison "meilleur modèle global" + reload API) ──
MLFLOW_URI=https://gviel-mlflow37.hf.space/
MODEL_NAME=fraud_detection

# ── Reload du modèle (POST /reload-model côté API) — même valeur que api/.env.* ──
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MODEL_RELOAD_TOKEN=

# ── S3 (transactions temps réel + sync fraudTest.csv/client_trx_analysis.csv) ──
S3_BUCKET=bucket-fraud-detection-gviel

# ── Email / SMTP (alerte fraude + rapport quotidien) ───────────────────────────
FRAUD_ALERT_EMAIL=<adresse qui doit recevoir les alertes fraude>
REPORT_EMAIL=<adresse qui doit recevoir le rapport quotidien>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<ton-adresse>@gmail.com
# Gmail App Password (pas ton mot de passe habituel) :
#   1. https://myaccount.google.com/security
#   2. "Mots de passe des applications"
#   3. créer un mot de passe de 16 caractères, le coller ci-dessous
SMTP_PASSWORD=<le code à 16 caractères>
# Fréquence du DAG dag_report — expression cron (la fenêtre de lookback du rapport
# est dérivée de cette même expression via croniter, pas une variable séparée)
DAG_REPORT_CRON=0 0 * * *

# ── DAG 3.3 (entraînement) ──────────────────────────────────────────────────────
WORK_DIR=work
DATA_PATH=data/fraudTest.csv
# Fréquence du DAG dag_train_model — expression cron
DAG_TRAIN_CRON=0 * * * *
SRC_DIR=/opt/airflow/src
PROJECT_CONFIG_PATH=/opt/airflow/project_config/models.yaml

# ── AWS S3 (upload transactions/training + fraudTest.csv/client_trx_analysis.csv,
# requis si APP_ENV=prod, vide en test) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
