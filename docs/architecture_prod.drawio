          <mxGeometry x="40" y="700" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Airflow (single block, local) -->
        <mxCell id="airflow" value="Airflow 3.2.2&#10;(local — LocalExecutor)&#10;&#10;3 DAGs :&#10;— ETL &amp; Fraud Detection (1/min)&#10;— Fraud Report (quotidien)&#10;— Model Training (conditionnel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="340" height="300" as="geometry" />
        </mxCell>

        <!-- Data layer -->
        <mxCell id="neon" value="PgSQL Neon&#10;fraud-detection-db&#10;(real_time_transactions)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="460" y="600" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="s3Trx" value="S3 bucket-fraud-detection-gviel&#10;(transactions JSON, fraudTest.csv,&#10;client_trx_analysis.csv)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="740" y="600" width="300" height="140" as="geometry" />
