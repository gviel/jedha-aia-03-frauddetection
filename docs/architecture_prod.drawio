        <mxCell id="s3Mlflow" value="S3 aws-s3-mlflow&#10;(artefacts modèles)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="860" y="260" width="240" height="110" as="geometry" />
