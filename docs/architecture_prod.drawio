<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="prod-architecture" name="Architecture Prod (Phase 5-6)">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Architecture Prod — Phase 5 (déploiement) &amp; Phase 6 (dashboard)" style="text;html=1;fontSize=26;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1000" height="40" as="geometry" />
        </mxCell>

        <!-- External systems -->
        <mxCell id="jedha" value="Real-time Payment API&#10;(sdacelo-real-time-fraud-detection.hf.space)" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="300" height="110" as="geometry" />
        </mxCell>
