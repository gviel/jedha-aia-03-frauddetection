# Variables de l'API (api/app.py) — copier en api/.env.test et api/.env.production
# (tous deux gitignorés). Mêmes clés dans les deux fichiers, valeurs vides quand non
# applicable à l'environnement (ex. AWS_* en test).
#
# api/.env.production est ce qu'il faut copier tel quel dans le dashboard Render
# (Settings → Environment) — Render ne lit aucun fichier local.

# ── Chargement du modèle ───────────────────────────────────────────────────────
# MODEL_ENV=test → modèle chargé depuis MODEL_PATH (pkl local, pas de MLflow ni S3)
# MODEL_ENV=prod|staging → modèle chargé depuis MLflow (artifact S3, filtré par MODEL_STATUS)
MODEL_ENV=test
MODEL_STATUS=best

# ── MLflow ─────────────────────────────────────────────────────────────────────
MLFLOW_URI=https://gviel-mlflow37.hf.space/
MODEL_NAME=fraud_detection

# ── Fichier modèle local (utilisé si MODEL_ENV=test — laisser vide en prod) ────
MODEL_PATH=model/best_model.pkl

# ── Stats client pour la feature diff_avg_amt (local en test, téléchargé depuis
# S3 en prod — cf. _download_client_stats_from_s3) ─────────────────────────────
CLIENT_STATS_PATH=work/client_trx_analysis.csv
CLIENT_STATS_S3_KEY=work/client_trx_analysis.csv
S3_BUCKET=bucket-fraud-detection-gviel

# ── Reload du modèle (POST /reload-model, déclenché par le DAG 3.3 après entraînement) ──
# Secret partagé avec airflow/.env.* — même valeur des deux côtés, sinon 403.
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MODEL_RELOAD_TOKEN=

# ── AWS S3 (lecture artifacts MLflow — requis si MODEL_ENV=prod|staging, vide en test) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3

# ── Postgres local (conteneur `db` de docker-compose.yml racine — l'API ne s'y
# connecte jamais elle-même, ces valeurs configurent uniquement le conteneur) ──
POSTGRES_USER=fraud
POSTGRES_PASSWORD=fraud
POSTGRES_DB=fraud
