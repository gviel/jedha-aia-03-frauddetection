# Template documenté des variables d'environnement du projet — à copier en `.env.test` et
# `.env.production` (tous deux gitignorés, jamais commités) pour le développement local.
#
# Trois contextes distincts utilisent ces variables, PAS deux :
#   1. Stack de test locale (`docker-compose.yml` racine : fraud_db + fraud_api_test)
#      → lit uniquement `.env.test`.
#   2. Stack Airflow locale (`airflow/start.sh` + `airflow/docker-compose.yml`)
#      → lit toujours `.env.test`, et lit EN PLUS `.env.production` quand APP_ENV=prod
#        (simulation locale de la prod pour les DAGs 3.1/3.2 : Neon + S3, cf. CLAUDE.md).
#   3. API réellement déployée sur Render (Phase 5)
#      → NE LIT AUCUN FICHIER LOCAL. Ses variables sont saisies directement dans le
#        dashboard Render (Settings → Environment). Voir docs/travail/render_deployment.md
#        pour la liste exacte à y renseigner.
#
# Copier ce fichier en .env.test puis remplir les valeurs réelles :
#   cp .env.template .env.test
# Copier également en .env.production pour les 4 variables prod-only (section dédiée ci-dessous) :
#   cp .env.template .env.production   # puis ne garder que la section "PROD-ONLY"

# ═══════════════════════════════════════════════════════════════════════════════
# COMMUN — va dans .env.test (utilisé par les 2 stacks locales, test comme prod)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Chargement du modèle ───────────────────────────────────────────────────────
# MODEL_ENV=test → modèle chargé depuis MODEL_PATH (pkl local, pas de MLflow ni S3)
# MODEL_ENV=prod|staging → modèle chargé depuis MLflow (artifact S3, filtré par MODEL_STATUS)
MODEL_ENV=test
MODEL_STATUS=best

# ── MLflow ─────────────────────────────────────────────────────────────────────
MLFLOW_URI=https://gviel-mlflow37.hf.space/
MODEL_NAME=fraud_detection

# ── Fichier modèle local (utilisé si MODEL_ENV=test) ───────────────────────────
MODEL_PATH=model/best_model.pkl

# ── Reload du modèle (POST /reload-model, déclenché par le DAG 3.3 après entraînement) ──
# Secret partagé entre l'API et le DAG train_model — même valeur des deux côtés, sinon 403.
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MODEL_RELOAD_TOKEN=

# ── Base de données locale (APP_ENV=test) ──────────────────────────────────────
DATABASE_URL=postgresql://fraud:fraud@localhost:5432/fraud
POSTGRES_USER=fraud
POSTGRES_PASSWORD=fraud
POSTGRES_DB=fraud

# ── API de prédiction (appelée par le DAG ETL & Fraud Detection) ──────────────
FRAUD_API_URL=http://localhost:8000

# ── Email / SMTP (partagé test/prod, indépendant de APP_ENV — cf. airflow/start.sh) ──
FRAUD_ALERT_EMAIL=<adresse qui doit recevoir les alertes fraude>
REPORT_EMAIL=<adresse qui doit recevoir le rapport quotidien>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<ton-adresse>@gmail.com
# Gmail App Password (pas ton mot de passe habituel) :
#   1. https://myaccount.google.com/security
#   2. "Mots de passe des applications"
#   3. créer un mot de passe de 16 caractères, le coller ci-dessous
SMTP_PASSWORD=<le code à 16 caractères>

# ── Paramètres des DAGs Airflow ────────────────────────────────────────────────
FRAUD_THRESHOLD=0.7           # seuil d'alerte fraude (0.0 – 1.0)
REPORT_LOOKBACK_HOURS=24      # période couverte par le rapport
WORK_DIR=work                 # stockage local des transactions (MODEL_ENV=test)
S3_BUCKET=bucket-fraud-detection-gviel  # bucket transactions/training (Phase 5) — distinct de aws-s3-mlflow

# ═══════════════════════════════════════════════════════════════════════════════
# PROD-ONLY — va dans .env.production (chargé EN PLUS de .env.test quand APP_ENV=prod)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Base de données Neon (Phase 5) ─────────────────────────────────────────────
DATABASE_URL_PROD=

# ── AWS S3 (upload transactions/training + lecture artifacts MLflow si MODEL_ENV=prod) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3

# ═══════════════════════════════════════════════════════════════════════════════
# RENDER — à saisir dans le dashboard Render (Settings → Environment), PAS ici
# ═══════════════════════════════════════════════════════════════════════════════
# MODEL_ENV=prod
# MODEL_STATUS=best
# MLFLOW_URI=https://gviel-mlflow37.hf.space/
# MODEL_NAME=fraud_detection
# MODEL_RELOAD_TOKEN=          (même valeur que celle utilisée par le DAG 3.3 en local)
# AWS_ACCESS_KEY_ID=           (lecture artifacts MLflow sur S3 aws-s3-mlflow)
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-3
# CLIENT_STATS_PATH=           (optionnel — défaut work/client_trx_analysis.csv, l'API le
#                                télécharge depuis S3 bucket-fraud-detection-gviel au démarrage)
